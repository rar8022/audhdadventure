# Copy this file to .env.local and fill in real values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used to build absolute OAuth redirect URLs. Set this to your deployed
# domain in production (e.g. https://anaudhdadventure.com); localhost is fine
# for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
